{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/shadcn-ui": [
        "./src/lib-ui/shadcn-ui"
      ],
      "@/shadcn-ui/*": [
        "./src/lib-ui/shadcn-ui/*"
      ],
      "@/shadcn-ui/lib/utils": [
        "./src/lib-ui/shadcn-ui/utils/utils"
      ],
      "@/shadcn-ui/hooks": [
        "./src/lib-ui/shadcn-ui/hooks"
      ],
      "@/lib-ui": [
        "./src/lib-ui"
      ],
      "@/lib-ui/*": [
        "./src/lib-ui/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/shared-infra/backend-firebase/functions/**"
  ]
}
