{
	"servers": {
		"repomix": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"repomix",
				"--mcp"
			]
		},
		"ESLint": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@eslint/mcp@latest"
			]
		},
		"next-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"next-devtools-mcp@latest"
			]
		},
		"shadcn": {
			"command": "npx",
			"args": [
				"shadcn@latest",
				"mcp"
			],
			"type": "stdio"
		},
		"memory": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-memory"
			],
			"env": {
				"MEMORY_FILE_PATH": "./.memory/knowledge-graph.json"
			}
		},
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"."
			]
		},
		"chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp"
			]
		},
//		"sonarqube": {
//			"type": "stdio",
//			"command": "npx",
//			"args": [
//				"-y",
//				"@sonarqube/mcp-server"
//			],
//			"env": {
//				"SONARQUBE_URL": "${input:sonarqube-url}",
//				"SONARQUBE_TOKEN": "${input:sonarqube-token}"
//			}
//		},
//		"codacy": {
//			"type": "stdio",
//			"command": "npx",
//			"args": [
//				"-y",
//				"@codacy/mcp-server"
//			],
//			"env": {
//				"CODACY_API_TOKEN": "${input:codacy-token}"
//			}
//		},
		"sequentialthinking": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			],
			"type": "stdio"
		},
		"everything": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-everything"
			],
			"type": "stdio"
		},
		"io.github.upstash/context7": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp@1.0.31"
			],
			"env": {
				"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
			}
		},
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp@0.0.1a4"
			]
		},
		"oraios/serena": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--context",
				"ide",
				"--project",
				"${workspaceFolder}",
				"--open-web-dashboard",
				"false"
			]
		}
	},
	"inputs": [
		{
			"id": "sonarqube-url",
			"type": "promptString",
			"description": "SonarQube server URL (e.g. http://localhost:9000)"
		},
		{
			"id": "sonarqube-token",
			"type": "promptString",
			"description": "SonarQube authentication token",
			"password": true
		},
		{
			"id": "codacy-token",
			"type": "promptString",
			"description": "Codacy API token",
			"password": true
		},
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		}
	]
}