{
	"inputs": [
		{
			"id": "sonarqube-url",
			"type": "promptString",
			"description": "SonarQube server URL (e.g. http://localhost:9000)"
		},
		{
			"id": "sonarqube-token",
			"type": "promptString",
			"description": "SonarQube authentication token",
			"password": true
		},
		{
			"id": "codacy-token",
			"type": "promptString",
			"description": "Codacy API token",
			"password": true
		}
	],
	"servers": {
		"repomix": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"repomix",
				"--mcp"
			]
		},
		"ESLint": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@eslint/mcp@latest"
			]
		},
		"next-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"next-devtools-mcp@latest"
			]
		},
		"shadcn": {
			"command": "npx",
			"args": [
				"shadcn@latest",
				"mcp"
			],
			"type": "stdio"
		},
		"memory": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-memory"
			],
			"env": {
				"MEMORY_FILE_PATH": "./docs/knowledge-graph.json"
			}
		},
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"."
			]
		},
		"sequential-thinking": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		},
		"chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp"
			]
		},
		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp"
		},
		"sonarqube": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@sonarqube/mcp-server"
			],
			"env": {
				"SONARQUBE_URL": "${input:sonarqube-url}",
				"SONARQUBE_TOKEN": "${input:sonarqube-token}"
			}
		},
		"codacy": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@codacy/mcp-server"
			],
			"env": {
				"CODACY_API_TOKEN": "${input:codacy-token}"
			}
		}
	}
}